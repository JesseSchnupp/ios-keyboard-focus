{
  "name": "@nullcheck/ios-keyboard-focus",
  "version": "0.2.2",
  "description": "Reliable mobile keyboard focus for iOS and Android modals in React",
  "license": "MIT",
  "author": "Jesse Schnupp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JesseSchnupp/ios-keyboard-focus.git",
    "directory": "packages/ios-keyboard-focus"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/JesseSchnupp/ios-keyboard-focus#readme",
  "bugs": {
    "url": "https://github.com/JesseSchnupp/ios-keyboard-focus/issues"
  },
  "keywords": [
    "ios",
    "keyboard",
    "focus",
    "modal",
    "react",
    "safari",
    "mobile",
    "visual-viewport"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5"
  }
}
